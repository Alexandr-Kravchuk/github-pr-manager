<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy for the PR Dashboard on Windows (ts1-core-dev04).

  IIS terminates TLS on 443 and forwards to the Node process bound to
  127.0.0.1:3737 (the WinSW service - see scripts/prdash.xml). Node is never
  exposed directly; 3737 stays closed at the firewall.

  PREREQUISITES (server-level, not in this file - see README "Windows"):
    - Install URL Rewrite + Application Request Routing (ARR); enable ARR proxy.
    - ARR "Response buffer threshold" = 0 (otherwise SSE is buffered, not streamed).
    - ARR proxy timeout > the 25s SSE heartbeat (e.g. 00:10:00).
    - Allow the X-Forwarded-* server variables (applicationHost.config /
      "Server Variables" in URL Rewrite) or drop the <serverVariables> block.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNext" stopProcessing="true">
          <match url="(.*)" />
          <serverVariables>
            <!-- TLS is terminated here; tell the app its real public scheme/host.
                 AUTH_URL still pins the OAuth callback origin regardless. -->
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
          <!-- IPv4 literal on purpose: Next listens on 127.0.0.1, and "localhost"
               can resolve to ::1, which would not match (EADDR / 502). -->
          <action type="Rewrite" url="http://127.0.0.1:3737/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

  <!-- SSE endpoint: never compress (compression forces buffering, which kills
       the live stream). Buffering-off and timeout are ARR server-wide settings
       documented in the README. -->
  <location path="api/stream">
    <system.webServer>
      <urlCompression doStaticCompression="false" doDynamicCompression="false" />
    </system.webServer>
  </location>
</configuration>
